# --- Keep build outputs (HLS/Vivado reports, logs, bitstreams) tracked so they
#     can be reviewed in the repo. Only ignore locks and editor/OS noise. ---

# Xilinx lock/journal/backup noise (useless to read, churn on every run)
.Xil/
*.jou
*.str
vivado*.backup*
*.wdb

# Python
__pycache__/
*.pyc

# Generated input data (regenerate deterministically with gen_inputs.py)
*.npz

# macOS
.DS_Store
